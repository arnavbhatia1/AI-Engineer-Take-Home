# Local: copy this file to .streamlit/secrets.toml (git-ignored) and fill in.
# Streamlit Community Cloud: paste these lines into the app's "Secrets" box
# (Manage app -> Settings -> Secrets). Do NOT commit the real file.

ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# Optional - override the vision model (default "claude-opus-4-8").
# For the fastest results toward the 5-second target:
# LABEL_MODEL = "claude-sonnet-5"
