# Copy to .env for local development (or just export these in your shell).
# .env is git-ignored — never commit real keys.

# Required for live label reading. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — model used for vision extraction. Default: claude-opus-4-8
# For the fastest turnaround toward the 5-second target, try a faster tier:
#   LABEL_MODEL=claude-sonnet-5
#   LABEL_MODEL=claude-haiku-4-5

# Optional — how many labels to analyse in parallel during batch runs (default 6).
# BATCH_MAX_WORKERS=6
